PORT=3000

# ── Speaker diarization (optional but recommended) ──────────────────────────
# Requires running: python diarize_server.py  (see diarize_server.py for setup)
# Get a FREE Hugging Face token at hf.co/settings/tokens
# Accept model terms at hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_your_token_here
# DIARIZE_URL defaults to http://127.0.0.1:8001 when HF_TOKEN is set
# DIARIZE_URL=http://127.0.0.1:8001

# ── Sentiment (vision) ─────────────────────────────────────────────────────────
# Required. Only Gemini supports free vision — used exclusively for sentiment.
# aistudio.google.com → Get API key (no credit card)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Transcription (audio) ──────────────────────────────────────────────────────
# Order: Groq Whisper → Gemini fallback
# Groq: console.groq.com (free, no credit card) — 7,200 audio seconds/day
GROQ_API_KEY=your_groq_api_key_here

# ── Suggestions (LLM) ──────────────────────────────────────────────────────────
# Order: OpenRouter → Cerebras → Mistral → Groq → Gemini (last resort)
# Add as many keys as you have to maximise uptime.

# OpenRouter: openrouter.ai (free :free models, no daily cap, just RPM throttled)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cerebras: cloud.cerebras.ai (free tier, very fast Llama 3.3 70B)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Mistral: console.mistral.ai (free tier, mistral-small-latest)
MISTRAL_API_KEY=your_mistral_api_key_here
