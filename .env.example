PORT=3000

# Primary: Google AI Studio — free, no credit card — aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback 1: Groq — free, no credit card — console.groq.com
# Used for transcription (Whisper) and suggestions (Llama 3.3 70B)
GROQ_API_KEY=your_groq_api_key_here

# Fallback 2: OpenRouter — free models available — openrouter.ai
# Used for suggestions when Gemini + Groq are both exhausted
OPENROUTER_API_KEY=your_openrouter_api_key_here
