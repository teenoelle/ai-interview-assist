# ─────────────────────────────────────────────────────────────────────────────
# AI Interview Assistant — environment configuration
# Copy this file to .env and fill in your keys before running the server.
# ─────────────────────────────────────────────────────────────────────────────

# Required — Gemini (transcription fallback, sentiment, context processing)
GEMINI_API_KEY=

# Optional — enables Claude Haiku for suggestions & sentiment (highest quality)
ANTHROPIC_API_KEY=

# Optional — Groq Whisper (fast cloud transcription fallback; add a second key for higher limits)
GROQ_API_KEY=
GROQ_API_KEY_2=

# Optional — extra suggestion providers (used in fallback chain)
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
QWEN_API_KEY=

# ─── Local Whisper (lowest latency transcription) ─────────────────────────────
# Run start_whisper.bat first, then set WHISPER_URL to point to it.
# Compatible with faster-whisper-server, whisper.cpp HTTP, or any OpenAI ASR server.
#
#   Recommended setup:
#     pip install faster-whisper-server
#     faster-whisper-server --port 8000 Systran/faster-whisper-large-v3
#   Or just double-click start_whisper.bat
#
WHISPER_URL=http://localhost:8000
WHISPER_MODEL=Systran/faster-whisper-large-v3

# ─── Local Ollama (offline suggestion fallback) ───────────────────────────────
# Install Ollama from https://ollama.com, then: ollama pull llama3.2
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
# Comma-separated list of models to try in order before cloud fallback
OLLAMA_MODELS=llama3.2:latest

# ─── Speaker diarization (who said what) ─────────────────────────────────────
# Requires a Hugging Face token with pyannote access.
# See: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=
# Override default diarization server address (default: http://127.0.0.1:8001)
# DIARIZE_URL=http://127.0.0.1:8001

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# Optional — network token auth (protects WebSocket and API endpoints)
# Set APP_TOKEN to any secret string; clients must send it as a header or query param.
# Leave blank to disable auth (safe for local use).
APP_TOKEN=

# ─── Piper TTS (offline voice hints) ─────────────────────────────────────────
# Download piper from https://github.com/rhasspy/piper and place voice .onnx files in a folder.
# PIPER_BINARY=C:/path/to/piper.exe
# PIPER_MODELS_DIR=C:/path/to/voices
